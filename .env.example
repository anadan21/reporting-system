APP_NAME=SIBIMA
APP_ENV=local
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# Untuk MySQL, uncomment dan isi baris di bawah:
 DB_CONNECTION=mysql
 DB_HOST=127.0.0.1
 DB_PORT=3306
 DB_DATABASE=sibima_db
 DB_USERNAME=root
 DB_PASSWORD=

# PENTING: Gunakan 'file' bukan 'database' agar tidak butuh tabel sessions
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# PENTING: Gunakan 'sync' agar tidak butuh worker queue
QUEUE_CONNECTION=sync

# PENTING: Gunakan 'file' agar tidak butuh tabel cache
CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Untuk development/testing, gunakan 'log' agar email tidak benar-benar terkirim
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@sibima.com"
MAIL_FROM_NAME="${APP_NAME}"

# Email tujuan notifikasi laporan baru
TECHNICAL_TEAM_EMAIL=admin@it.com

VITE_APP_NAME="${APP_NAME}"
VITE_API_URL=http://localhost:8000/api
